# =============================================================================
# Career Guidance AI — Environment Template
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Environment is AUTO-DETECTED at startup from PG_HOST:
#   • Contains "supabase.co"  → Supabase (cloud, SSL enforced automatically)
#   • localhost / 127.0.0.1   → Local PostgreSQL
#   • PG_HOST not set         → Startup error (PostgreSQL is required)
#
# To switch environments, comment/uncomment the relevant DB block below.
# =============================================================================


# =============================================================================
# DATABASE — LOCAL PostgreSQL
# Uncomment this block for local development.
# =============================================================================
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=YOUR_LOCAL_PG_PASSWORD
PG_DB=resumes


# =============================================================================
# DATABASE — SUPABASE (cloud)
# Uncomment this block (and comment out LOCAL above) to use Supabase.
# Find your connection details at:
#   Supabase Dashboard → Settings → Database → Connection string (Session pooler)
# =============================================================================
# PG_HOST=db.YOUR_PROJECT_REF.supabase.co
# PG_PORT=5432
# PG_USER=postgres
# PG_PASSWORD=YOUR_SUPABASE_DB_PASSWORD
# PG_DB=postgres


# =============================================================================
# AI SERVICES
# Gemini: https://aistudio.google.com/apikey
# Groq:   https://console.groq.com/keys
# =============================================================================
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_SMALL_MODEL=gemini-3-flash-preview
GEMINI_LARGE_MODEL=gemini-3-pro-preview
GEMINI_MOCK_MODE=false

GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_MODEL=llama-3.3-70b-versatile

# =============================================================================
# GOOGLE SEARCH API (optional — for skill taxonomy builder)
# https://developers.google.com/custom-search/v1/introduction
# =============================================================================
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY
GOOGLE_SEARCH_ENGINE_ID=YOUR_SEARCH_ENGINE_ID

# =============================================================================
# EMBEDDINGS
# =============================================================================
EMBEDDING_MODEL=gemini-embedding-2-preview
GOOGLE_EMBEDDING_ENABLED=true
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_CACHE_MAX_ITEMS=2000
EMBEDDING_FALLBACK_ENABLED=true

# =============================================================================
# ASYNC EMBEDDING PIPELINE (Celery + Redis)
# Use managed Redis in production and set these URLs accordingly.
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_DEFAULT_QUEUE=default
CELERY_EMBEDDINGS_QUEUE=embeddings
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=120
CELERY_TASK_TIME_LIMIT_SECONDS=180
EMBEDDING_TASK_MAX_RETRIES=3
EMBEDDING_TASK_RETRY_BACKOFF_SECONDS=10

# =============================================================================
# FILE STORAGE
# =============================================================================
FILE_STORAGE_PATH=./data/raw_files
MAX_PARSE_TOKENS=12000

# Skill taxonomy JSON (optional — leave blank to use built-in defaults)
SKILL_TAXONOMY_PATH=./resume_pipeline/skill_taxonomy.json

# =============================================================================
# PARSING THRESHOLDS (optional — change only if you need to tune accuracy)
# =============================================================================
LLM_CONFIDENCE_THRESHOLD=0.7
CGPA_MISMATCH_THRESHOLD=0.2
MAX_SUMMARY_SENTENCES=10
MAX_UNKNOWN_SKILLS=5
LONG_DOC_WORD_THRESHOLD=2000

# =============================================================================
# API SERVER
# =============================================================================
API_HOST=localhost
API_PORT=8000

# =============================================================================
# JWT AUTHENTICATION
# Generate a strong key with: openssl rand -hex 32
# Use a DIFFERENT key for local vs production.
# =============================================================================
SECRET_KEY=GENERATE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# =============================================================================
# EMAIL — Gmail SMTP (for verification emails)
# Use an App Password — NOT your regular Gmail password:
# https://support.google.com/accounts/answer/185833
# Leave blank to disable email verification (dev mode).
# =============================================================================
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=YOUR_16_CHAR_APP_PASSWORD
FRONTEND_URL=http://localhost:5173
